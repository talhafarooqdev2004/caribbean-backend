NODE_ENV=development
PORT=5000
FRONTEND_URL=https://caribnewswire.com
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
SESSION_SECRET=replace-with-session-secret
JWT_SECRET=replace-with-jwt-secret
JWT_EXPIRES_IN=7d

MONGODB_URI=mongodb://127.0.0.1:27017/caribnews
MONGODB_DB_NAME=caribnews

ADMIN_USERNAME=admin
ADMIN_PASSWORD=CaribNews@123
# Admin panel login checks ADMIN_USERNAME / ADMIN_PASSWORD from env (not the Mongo password hash).

# Operations inbox: media signups, Join the Network, contact form, payment alerts, etc.
# The journalist digest is sent to each user's portal email — not to ADMIN_EMAIL.
# Set this to an address you read (e.g. same as SMTP_USER for dev), or use info@ with forwarding.
ADMIN_EMAIL=info@caribnewswire.com

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# Square — sandbox (Admin → Payments: test mode ON uses these)
SQUARE_SANDBOX_APP_ID=
SQUARE_SANDBOX_ACCESS_TOKEN=
SQUARE_SANDBOX_LOCATION_ID=

# Square — production (Admin → Payments: test mode OFF uses these)
SQUARE_PROD_APP_ID=
SQUARE_PROD_ACCESS_TOKEN=
SQUARE_LOCATION_ID=

# Webhooks (optional)
SQUARE_WEBHOOK_SIGNATURE_KEY=
# Local/dev only: skip real Square charges (restart API after changing)
SQUARE_BYPASS_FOR_TESTING=false

# Redis (optional) — API response cache for newsroom lists, portal reads, admin lists.
# When unset, all reads go to MongoDB as before (newsroom filters will feel slower on repeat).
# Example: redis://127.0.0.1:6379/0
REDIS_URL=
# Public newsroom press list: fixed 1h TTL (3600s), keys `carib:newsroom:list:{stableQueryJson}` (code constant). Writes (approve/edit/delete) clear all those keys when Redis bumps the admin list version.
# TTL overrides (seconds) for other Redis paths; defaults are sensible if omitted
# Log each public newsroom list cache decision (HIT/MISS/OFF): 1=on
# LOG_PUBLIC_PRESS_LIST_REDIS=1
# With API running: npm run verify:redis-press-list
# Cold MISS then HIT (local only): npm run verify:redis-press-list -- --fresh
# REDIS_CACHE_TTL_PUBLIC_DETAIL_SEC=120
# REDIS_CACHE_TTL_ADMIN_PR_LIST_SEC=30
# Portal profile/credits/submissions/bookmarks/dashboard: fixed 3600s in code (REDIS_CACHE_TTL_PORTAL_SEC is unused for those reads).
# REDIS_CACHE_TTL_PORTAL_SEC=20
# REDIS_CACHE_TTL_MEDIA_SIGNUPS_SEC=30

# Emergency maintenance / IP-gate control (POST with secret header or ?token=)
# SITE_ACCESS_CONTROL_SECRET=replace-with-long-random-secret
