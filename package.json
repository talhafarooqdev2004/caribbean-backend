{
  "name": "carib-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Carib Newswire Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "db:reset-testing": "tsx scripts/reset-testing-db.ts",
    "db:reset-full": "tsx scripts/reset-db-full.ts",
    "verify:redis-press-list": "tsx scripts/verify-press-list-redis.ts"
  },
  "keywords": [
